Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Defining", " ", "the", " ", "oscillation"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"pendulumPlot", "[", 
      RowBox[{
       RowBox[{"gam_", "?", "NumericQ"}], ",", "\[IndentingNewLine]", 
       RowBox[{"om_", "?", "NumericQ"}], ",", "\[IndentingNewLine]", 
       RowBox[{"F0_", "?", "NumericQ"}], ",", "\[IndentingNewLine]", 
       RowBox[{"k_", "?", "NumericQ"}], ",", "\[IndentingNewLine]", 
       RowBox[{"m_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"sol", ",", "tmax"}], "}"}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Transient", " ", "decay", " ", "scale"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"tmax", "=", 
         RowBox[{"Min", "[", 
          RowBox[{
           RowBox[{"30", "*", 
            RowBox[{"m", "/", "gam"}]}], ",", 
           RowBox[{"40", "*", 
            RowBox[{"(", 
             RowBox[{"2", "*", 
              RowBox[{"Pi", "/", "om"}]}], ")"}]}], ",", "2000"}], "]"}]}], ";",
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Solve", " ", "ODE"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"sol", "=", 
         RowBox[{
          RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
               RowBox[{"y", "[", "t", "]"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"y", "'"}], "[", "t", "]"}], "==", 
               RowBox[{
                RowBox[{"1", "/", "m"}], " ", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"F0", "*", 
                   RowBox[{"Cos", "[", 
                    RowBox[{"om", "*", "t"}], "]"}]}], "-", 
                  RowBox[{"gam", "*", 
                   RowBox[{"y", "[", "t", "]"}]}], "-", 
                  RowBox[{"k", "*", 
                   RowBox[{"x", "[", "t", "]"}]}]}], ")"}]}]}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"x", "[", "0", "]"}], "==", "0"}], ",", 
              RowBox[{
               RowBox[{"y", "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"x", ",", "y"}], "}"}], ",", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Plot", " ", "phase", " ", "space"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"ParametricPlot", "[", 
         RowBox[{
          RowBox[{"Evaluate", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"x", "[", "t", "]"}], ",", 
              RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", " ", "sol"}], 
           "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"AxesLabel", "->", 
           RowBox[{"{", 
            RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pendulumPlot", "[", 
      RowBox[{"gam", ",", "om", ",", "F0", ",", "k", ",", "m"}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"gam", ",", "0.01", ",", "2"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"om", ",", "0.1", ",", "5"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"F0", ",", "0", ",", "5"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"k", ",", "0", ",", "5"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"m", ",", "0.1", ",", "5"}], "}"}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
