<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="UTF-8">
    <title>Harmonic Oscillator - Phase Space</title>
    <style>
        body { font-family: sans-serif; text-align: center; background: #f0f0f0; padding: 20px; }
        canvas { background: white; border: 1px solid #ccc; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
        .controls { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; max-width: 600px; margin: 20px auto; text-align: left; background: white; padding: 15px; border-radius: 8px; }
        label { font-size: 14px; }
    </style>
</head>
<body>

    <h2>Προσομοίωση Αρμονικού Ταλαντωτή</h2>
    
    <canvas id="canvas" width="600" height="400"></canvas>

    <div class="controls">
        <label>Απόσβεση (gam): <input type="range" id="gam" min="0.01" max="2" step="0.01" value="0.54"></label>
        <label>Συχνότητα (om): <input type="range" id="om" min="0.1" max="5" step="0.1" value="1.21"></label>
        <label>Δύναμη (F0): <input type="range" id="F0" min="0" max="5" step="0.1" value="2.7"></label>
        <label>Σταθερά (k): <input type="range" id="k" min="0.1" max="5" step="0.1" value="1.64"></label>
        <label>Μάζα (m): <input type="range" id="m" min="0.1" max="5" step="0.1" value="2.28"></label>
    </div>

    <script>
        const canvas = document.getElementById('canvas');
        const ctx = canvas.getContext('2d');

        // Παράμετροι
        let x = 0, y = 0, t = 0;
        const dt = 0.05;
        let points = [];

        function draw() {
            // Λήψη τιμών από τα sliders
            let gam = parseFloat(document.getElementById('gam').value);
            let om = parseFloat(document.getElementById('om').value);
            let F0 = parseFloat(document.getElementById('F0').value);
            let k = parseFloat(document.getElementById('k').value);
            let m = parseFloat(document.getElementById('m').value);

            // Euler Method για την επίλυση της Δ.Ε. (όπως το NDSolve)
            let force = F0 * Math.cos(om * t) - gam * y - k * x;
            let acceleration = force / m;
            
            y += acceleration * dt; // Ταχύτητα
            x += y * dt;            // Θέση
            t += dt;

            // Αποθήκευση σημείου για το Phase Space
            points.push({x: x, y: y});
            if (points.length > 1000) points.shift();

            // Σχεδίαση
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Άξονες
            ctx.strokeStyle = '#ddd';
            ctx.beginPath();
            ctx.moveTo(300, 0); ctx.lineTo(300, 400);
            ctx.moveTo(0, 200); ctx.lineTo(600, 200);
            ctx.stroke();

            // Τροχιά (Phase Space)
            ctx.strokeStyle = 'blue';
            ctx.beginPath();
            points.forEach((p, i) => {
                let px = 300 + p.x * 40;
                let py = 200 - p.y * 40;
                if (i === 0) ctx.moveTo(px, py);
                else ctx.lineTo(px, py);
            });
            ctx.stroke();

            // Το τρέχον σημείο (η μπάλα)
            ctx.fillStyle = 'red';
            ctx.beginPath();
            ctx.arc(300 + x * 40, 200 - y * 40, 5, 0, Math.PI * 2);
            ctx.fill();

            requestAnimationFrame(draw);
        }

        draw();
    </script>
</body>
</html>

